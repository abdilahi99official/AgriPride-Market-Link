# Normalize text files in the repository
* text=auto

# Use Linux line endings for source and deployment files
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf

# Keep Windows scripts as CRLF
*.ps1 text eol=crlf

# Treat images as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
